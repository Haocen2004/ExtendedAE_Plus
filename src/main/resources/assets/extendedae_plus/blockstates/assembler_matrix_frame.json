{
  "multipart": [
    {
      "when": { "powered": "false", "shape": "block" },
      "apply": { "model": "extendedae_plus:block/matrix/assembler_matrix_frame_block_off" }
    },
    {
      "when": { "powered": "true", "shape": "block" },
      "apply": { "model": "extendedae_plus:block/matrix/assembler_matrix_frame_block_on" }
    },
    {
      "when": { "powered": "false", "shape": "column_x" },
      "apply": { "model": "extendedae_plus:block/matrix/assembler_matrix_frame_column_off", "x": 90, "y": 90 }
    },
    {
      "when": { "powered": "true", "shape": "column_x" },
      "apply": { "model": "extendedae_plus:block/matrix/assembler_matrix_frame_column_on", "x": 90, "y": 90 }
    },
    {
      "when": { "powered": "false", "shape": "column_y" },
      "apply": { "model": "extendedae_plus:block/matrix/assembler_matrix_frame_column_off" }
    },
    {
      "when": { "powered": "true", "shape": "column_y" },
      "apply": { "model": "extendedae_plus:block/matrix/assembler_matrix_frame_column_on" }
    },
    {
      "when": { "powered": "false", "shape": "column_z" },
      "apply": { "model": "extendedae_plus:block/matrix/assembler_matrix_frame_column_off", "x": 90 }
    },
    {
      "when": { "powered": "true", "shape": "column_z" },
      "apply": { "model": "extendedae_plus:block/matrix/assembler_matrix_frame_column_on", "x": 90 }
    }
  ]
}
